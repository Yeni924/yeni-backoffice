app = "yeni-backoffice-demo"
primary_region = "nrt"

[build]
  dockerfile = "Dockerfile"

[env]
  SPRING_PROFILES_ACTIVE = "fly"
  JAVA_TOOL_OPTIONS = "-Xmx384m -XX:+UseSerialGC"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = "off"
  auto_start_machines = true
  min_machines_running = 1

[[vm]]
  memory = "512mb"
  cpu_kind = "shared"
  cpus = 1
